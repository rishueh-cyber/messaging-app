PORT=5000
# Use MongoDB Atlas for cloud-based database:
# 1. Go to https://www.mongodb.com/cloud/atlas
# 2. Create free account and cluster
# 3. Get connection string: mongodb+srv://username:password@cluster.mongodb.net/chatflow?retryWrites=true&w=majority
MONGODB_URI=mongodb://127.0.0.1:27017/chatflow
NODE_ENV=development
